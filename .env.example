# Copy to .env and adjust. All vars are optional; sensible defaults apply.
# Settings are read by jobpipe/config.py (pydantic-settings), prefix JOBPIPE_.

# --- Core extraction ---
JOBPIPE_WINDOW_HOURS=48           # only keep postings published within N hours; 0 = keep all
JOBPIPE_REQUIRE_SENIORITY=false   # true = require an explicit junior/entry/mid/grad token

# --- Concurrency / politeness ---
JOBPIPE_HTTP_CONCURRENCY=20       # max concurrent HTTP (API/static) requests
JOBPIPE_BROWSER_CONCURRENCY=8     # max concurrent stealth-browser sessions (<=10 on 8GB RAM)
JOBPIPE_PER_DOMAIN_DELAY=1.5      # min seconds between requests to the same domain
JOBPIPE_REQUEST_TIMEOUT=30        # per-request timeout (seconds)

# --- Paths ---
JOBPIPE_SEED_CSV=data/seed_companies.csv
JOBPIPE_OUTPUT_XLSX=data/output/jobs.xlsx
JOBPIPE_STATE_DB=data/output/state.sqlite        # dedup + checkpoint store
JOBPIPE_ADAPTIVE_DB=data/output/adaptive.sqlite  # scrapling element fingerprints (MUST persist)
JOBPIPE_KEYWORDS=config/keywords.yaml

# --- Optional discovery / proxy layers (interfaces only; unconfigured by default) ---
# JOBPIPE_PROXY_URLS=http://user:pass@host1:port,http://user:pass@host2:port
# JOBPIPE_SERP_API_KEY=
# JOBPIPE_SERP_PROVIDER=serpapi
